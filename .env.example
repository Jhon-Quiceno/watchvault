# Watchvault environment variables
# Copy this file to .env.local and fill in the values you have.
# All variables here are server-only and must never be prefixed with NEXT_PUBLIC_.

# TMDB (The Movie Database) API key used to search/fetch movie and series metadata.
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Base URL for the TMDB REST API. Defaults to the public TMDB API if unset.
TMDB_API_BASE_URL=https://api.themoviedb.org/3

# GraphQL endpoint for AniList, used to search/fetch anime metadata.
ANILIST_GRAPHQL_URL=https://graphql.anilist.co

# Reserved for a future PostgreSQL-backed repository implementation.
# Not required for the current JSON file-based storage.
DATABASE_URL=
